<svg width="300" height="400" xmlns="http://www.w3.org/2000/svg">
  <!-- 背景渐变 -->
  <defs>
    <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- 背景 -->
  <rect width="300" height="400" fill="url(#grad1)"/>
  
  <!-- 电影图标 -->
  <g transform="translate(150, 150)">
    <!-- 胶片框 -->
    <rect x="-60" y="-80" width="120" height="160" rx="8" fill="white" opacity="0.9"/>
    
    <!-- 胶片孔 -->
    <circle cx="-50" cy="-60" r="5" fill="#667eea"/>
    <circle cx="-50" cy="-30" r="5" fill="#667eea"/>
    <circle cx="-50" cy="0" r="5" fill="#667eea"/>
    <circle cx="-50" cy="30" r="5" fill="#667eea"/>
    <circle cx="-50" cy="60" r="5" fill="#667eea"/>
    
    <circle cx="50" cy="-60" r="5" fill="#667eea"/>
    <circle cx="50" cy="-30" r="5" fill="#667eea"/>
    <circle cx="50" cy="0" r="5" fill="#667eea"/>
    <circle cx="50" cy="30" r="5" fill="#667eea"/>
    <circle cx="50" cy="60" r="5" fill="#667eea"/>
    
    <!-- 播放按钮 -->
    <polygon points="0,-15 20,0 0,15" fill="#667eea"/>
  </g>
  
  <!-- 文本 -->
  <text x="150" y="280" font-family="Arial" font-size="20" fill="white" text-anchor="middle" font-weight="bold">
    暂无海报
  </text>
  <text x="150" y="310" font-family="Arial" font-size="14" fill="white" text-anchor="middle" opacity="0.8">
    No Image Available
  </text>
</svg>
